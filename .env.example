# MongoDB
MONGODB_URI=mongodb://localhost:27017

# Public base URL used when generating QR codes (GET /dpp/:id/qr)
DPP_PUBLIC_URL=https://interfacer.dyne.org/dpps

# Public base URL of this service (used for file attachment URLs)
SERVER_URL=http://localhost:8080

# MinIO object storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=dpp-files
MINIO_USE_SSL=false

# DID authentication
BASE_DID_URL=https://did.dyne.org
DID_CONTEXT_PATH=/path/to/did-context.json
